# Database Config
DATABASE_URL=host=db port=5432 user=postgres password=postgres_secure_db_pass_2026 dbname=university_ocr sslmode=disable

# Go Backend Config
PORT=8080
JWT_SECRET=platform_jwt_secure_signing_secret_key_2026
UPLOAD_DIR=/var/data/uploads

# First-run admin bootstrap (created automatically on an empty database).
# If SEED_ADMIN_PASSWORD is left unset, a random password is generated and
# printed once to the server log on first startup. Optional overrides:
# SEED_ADMIN_EMAIL=admin@yourcompany.com
# SEED_ADMIN_PASSWORD=change-me-to-a-strong-password
# SEED_TENANT_NAME=Your Company
# SEED_TENANT_DOMAIN=yourcompany.com

# Python AI Worker Config
POLL_INTERVAL=5
WORKER_ID=docker-ocr-worker-01
OCR_PRIORITY=paddle,surya,doctr,tesseract
